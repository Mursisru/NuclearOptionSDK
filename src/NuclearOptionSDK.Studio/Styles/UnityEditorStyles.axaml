<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:NuclearOptionSDK.Studio.Controls">
  <Design.PreviewWith>
    <Border Width="400" Height="200" Classes="unity-dock"/>
  </Design.PreviewWith>

  <Style Selector="Window">
    <Setter Property="Background" Value="#1E1E1E"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="FontFamily" Value="Segoe UI, Arial"/>
  </Style>

  <!-- Unity panel chrome -->
  <Style Selector="Border.unity-dock">
    <Setter Property="Background" Value="#2B2B2B"/>
    <Setter Property="BorderBrush" Value="#1A1A1A"/>
    <Setter Property="BorderThickness" Value="1"/>
  </Style>

  <Style Selector="Border.panel">
    <Setter Property="Background" Value="#383838"/>
    <Setter Property="BorderBrush" Value="#1A1A1A"/>
    <Setter Property="BorderThickness" Value="1"/>
  </Style>

  <Style Selector="Border.unity-splitter">
    <Setter Property="Background" Value="#2A2A2A"/>
    <Setter Property="BorderBrush" Value="#141414"/>
    <Setter Property="BorderThickness" Value="0,1"/>
  </Style>

  <Style Selector="Border.unity-splitter:pointerover">
    <Setter Property="Background" Value="#007ACC"/>
  </Style>

  <Style Selector="GridSplitter.unity-splitter">
    <Setter Property="Background" Value="#2A2A2A"/>
    <Setter Property="MinWidth" Value="6"/>
    <Setter Property="MinHeight" Value="6"/>
  </Style>

  <Style Selector="GridSplitter.unity-splitter:pointerover">
    <Setter Property="Background" Value="#007ACC"/>
  </Style>

  <Style Selector="Border.unity-toolbar">
    <Setter Property="Background" Value="#3E3E3E"/>
    <Setter Property="BorderBrush" Value="#1A1A1A"/>
    <Setter Property="BorderThickness" Value="0,0,0,1"/>
    <Setter Property="MinHeight" Value="28"/>
  </Style>

  <Style Selector="Border.unity-dock-tab">
    <Setter Property="Background" Value="#3E3E3E"/>
    <Setter Property="BorderBrush" Value="#1A1A1A"/>
    <Setter Property="BorderThickness" Value="0,0,0,1"/>
    <Setter Property="Padding" Value="0"/>
  </Style>

  <Style Selector="TextBlock.unity-dock-title-compact">
    <Setter Property="Padding" Value="6,3"/>
    <Setter Property="FontSize" Value="10"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="#C8C8C8"/>
  </Style>

  <Style Selector="TextBlock.unity-dock-title">
    <Setter Property="Padding" Value="8,4"/>
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="#C8C8C8"/>
  </Style>

  <Style Selector="TabControl.hierarchy-tabs > TabItem">
    <Setter Property="FontSize" Value="10"/>
    <Setter Property="Padding" Value="6,3"/>
    <Setter Property="MinHeight" Value="22"/>
  </Style>

  <Style Selector="TreeView.hierarchy-tree">
    <Setter Property="FontSize" Value="10"/>
  </Style>

  <Style Selector="TextBox.hierarchy-field">
    <Setter Property="MinHeight" Value="20"/>
    <Setter Property="Padding" Value="4,2"/>
    <Setter Property="FontSize" Value="10"/>
  </Style>

  <Style Selector="TextBox.inspector-field">
    <Setter Property="MinHeight" Value="20"/>
    <Setter Property="Padding" Value="4,2"/>
    <Setter Property="FontSize" Value="10"/>
  </Style>

  <Style Selector="StackPanel.unity-inspector">
    <Setter Property="Spacing" Value="3"/>
  </Style>

  <Style Selector="ScrollViewer.unity-inspector-scroll">
    <Setter Property="Background" Value="#2B2B2B"/>
  </Style>

  <Style Selector="StackPanel.unity-inspector CheckBox">
    <Setter Property="FontSize" Value="10"/>
    <Setter Property="MinHeight" Value="18"/>
  </Style>

  <Style Selector="StackPanel.unity-inspector Button.compact">
    <Setter Property="MinHeight" Value="20"/>
    <Setter Property="Padding" Value="4,2"/>
  </Style>

  <Style Selector="Menu.unity-menu">
    <Setter Property="Background" Value="#3E3E3E"/>
    <Setter Property="Foreground" Value="#D4D4D4"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Height" Value="24"/>
  </Style>

  <Style Selector="TabControl.unity-tabs">
    <Setter Property="Background" Value="#2B2B2B"/>
    <Setter Property="BorderBrush" Value="#1A1A1A"/>
    <Setter Property="BorderThickness" Value="0"/>
  </Style>

  <Style Selector="TabControl.unity-tabs > TabItem">
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="Padding" Value="10,4"/>
    <Setter Property="Background" Value="#2D2D30"/>
    <Setter Property="Foreground" Value="#B0B0B0"/>
  </Style>

  <Style Selector="TabControl.unity-tabs > TabItem:selected">
    <Setter Property="Background" Value="#383838"/>
    <Setter Property="Foreground" Value="#FFFFFF"/>
  </Style>

  <!-- Вкладки без TabControl (нет пустой content-зоны, которая съедает высоту конструктора) -->
  <Style Selector="RadioButton.unity-tab">
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="Padding" Value="10,4"/>
    <Setter Property="MinHeight" Value="26"/>
    <Setter Property="Background" Value="#2D2D30"/>
    <Setter Property="Foreground" Value="#B0B0B0"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
      <ControlTemplate TargetType="RadioButton">
        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
          <ContentPresenter Content="{TemplateBinding Content}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>
  <Style Selector="RadioButton.unity-tab:pointerover">
    <Setter Property="Background" Value="#353535"/>
  </Style>
  <Style Selector="RadioButton.unity-tab:checked">
    <Setter Property="Background" Value="#383838"/>
    <Setter Property="Foreground" Value="#FFFFFF"/>
  </Style>

  <Style Selector="TabControl.compact-tabs TabItem">
    <Setter Property="FontSize" Value="10"/>
    <Setter Property="Padding" Value="6,3"/>
  </Style>

  <Style Selector="TextBlock.panel-header">
    <Setter Property="Background" Value="#404040"/>
    <Setter Property="Padding" Value="6,3"/>
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
  </Style>

  <Style Selector="Button.compact">
    <Setter Property="MinHeight" Value="22"/>
    <Setter Property="MinWidth" Value="22"/>
    <Setter Property="Padding" Value="6,2"/>
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="Background" Value="#4A4A4A"/>
    <Setter Property="BorderBrush" Value="#2A2A2A"/>
  </Style>

  <Style Selector="Button.icon-btn">
    <Setter Property="FontFamily" Value="Segoe UI, Arial"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
  </Style>

  <Style Selector="TextBox">
    <Setter Property="MinHeight" Value="22"/>
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="Background" Value="#2A2A2A"/>
    <Setter Property="BorderBrush" Value="#1A1A1A"/>
    <Setter Property="Foreground" Value="#D4D4D4"/>
  </Style>

  <Style Selector="TextBox.unity-console">
    <Setter Property="Background" Value="#1E1E1E"/>
    <Setter Property="BorderThickness" Value="0"/>
  </Style>

  <Style Selector="ComboBox">
    <Setter Property="MinHeight" Value="22"/>
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="Background" Value="#2A2A2A"/>
  </Style>

  <Style Selector="TreeView">
    <Setter Property="Background" Value="#2B2B2B"/>
    <Setter Property="FontSize" Value="11"/>
  </Style>

  <Style Selector="TreeView.compact-tree">
    <Setter Property="FontSize" Value="11"/>
  </Style>

  <Style Selector="TreeViewItem">
    <Setter Property="Padding" Value="2,1"/>
    <Setter Property="MinHeight" Value="18"/>
  </Style>

  <Style Selector="ListBox.unity-asset-list">
    <Setter Property="Background" Value="#2B2B2B"/>
    <Setter Property="FontSize" Value="11"/>
  </Style>

  <Style Selector="ComboBox.unity-layout-combo">
    <Setter Property="Background" Value="#383838"/>
    <Setter Property="FontSize" Value="10"/>
    <Setter Property="MinHeight" Value="22"/>
  </Style>

  <Style Selector="GridSplitter.unity-splitter:pointerover">
    <Setter Property="Background" Value="#007ACC"/>
  </Style>

  <Style Selector="Menu.unity-menu MenuItem">
    <Setter Property="Padding" Value="8,2"/>
  </Style>

  <Style Selector="ScrollViewer">
    <Setter Property="Background" Value="#2B2B2B"/>
  </Style>
</Styles>
