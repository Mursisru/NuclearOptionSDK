<UserControl xmlns="https://github.com/avaloniaui"

             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             xmlns:views="using:NuclearOptionSDK.Studio.Views"

             x:Class="NuclearOptionSDK.Studio.Views.ConstructorWorkspacePanel"

             HorizontalAlignment="Stretch"

             VerticalAlignment="Stretch">

  <DockPanel LastChildFill="True">

    <TabControl x:Name="SectionTabs" DockPanel.Dock="Top" Classes="unity-tabs compact-tabs" Margin="4,2,4,0">

      <TabItem Header="Logic"><Panel Height="0"/></TabItem>

      <TabItem Header="Audio"><Panel Height="0"/></TabItem>

      <TabItem Header="Mechanics"><Panel Height="0"/></TabItem>

      <TabItem Header="QOL"><Panel Height="0"/></TabItem>

    </TabControl>



    <Panel Margin="0,0,0,2">

      <views:LogicConstructorPanel x:Name="LogicConstructor"

                                   HorizontalAlignment="Stretch"

                                   VerticalAlignment="Stretch"/>

      <views:AudioConstructorPanel x:Name="AudioConstructor" IsVisible="False"

                                   HorizontalAlignment="Stretch"

                                   VerticalAlignment="Stretch"/>

      <views:GraphConstructorPanel x:Name="MechanicConstructor" IsVisible="False"

                                   HorizontalAlignment="Stretch"

                                   VerticalAlignment="Stretch"/>

      <views:GraphConstructorPanel x:Name="QolConstructor" IsVisible="False"

                                   HorizontalAlignment="Stretch"

                                   VerticalAlignment="Stretch"/>

    </Panel>

  </DockPanel>

</UserControl>

