<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="NuclearOptionSDK.Studio.Views.GameCodePanel">
  <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="1">
    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="2,1">
      <TextBox x:Name="FilterBox" Grid.Column="0" PlaceholderText="Filter types…" FontSize="10" MinHeight="20" Classes="hierarchy-field"/>
      <Button x:Name="RefreshButton" Grid.Column="1" Classes="compact" Content="↻" Width="22" MinHeight="20" Margin="2,0,0,0" ToolTip.Tip="Reload index from game DLL"/>
    </Grid>
    <StackPanel Grid.Row="1" Spacing="0" Margin="2,0">
      <CheckBox x:Name="PlainLanguageCheck" Content="Friendly labels" FontSize="9" IsChecked="True" Padding="0"/>
      <CheckBox x:Name="HideSystemNoiseCheck" Content="Hide system noise" FontSize="9" IsChecked="True" Padding="0"/>
      <CheckBox x:Name="ShowLifecycleCheck" Content="Show Unity lifecycle" FontSize="9" Padding="0"/>
    </StackPanel>
    <TextBlock x:Name="IndexStatusText" Grid.Row="2" FontSize="9" Opacity="0.6" Margin="4,0"/>
    <TreeView x:Name="TypeTree" Grid.Row="3" FontSize="10" Classes="compact-tree hierarchy-tree" Margin="1,0,1,1"/>
  </Grid>
</UserControl>
