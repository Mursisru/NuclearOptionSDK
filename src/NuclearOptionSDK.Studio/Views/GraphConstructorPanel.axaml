<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:NuclearOptionSDK.Studio.Views"
             x:Class="NuclearOptionSDK.Studio.Views.GraphConstructorPanel">
  <Grid RowDefinitions="Auto,*" Margin="4">
    <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,4">
      <Menu Grid.Column="0">
        <MenuItem Header="Project">
          <MenuItem x:Name="SaveMenuItem" Header="Save"/>
          <MenuItem x:Name="LoadMenuItem" Header="Load"/>
          <MenuItem x:Name="PreviewMenuItem" Header="Preview"/>
        </MenuItem>
      </Menu>
      <TextBlock x:Name="TitleText" Grid.Column="1" Classes="panel-header" VerticalAlignment="Center" Margin="8,0"/>
    </Grid>
    <views:LogicNodeCanvas x:Name="Canvas" Grid.Row="1"/>
  </Grid>
</UserControl>
