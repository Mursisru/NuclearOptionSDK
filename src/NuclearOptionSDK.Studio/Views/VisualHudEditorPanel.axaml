<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="NuclearOptionSDK.Studio.Views.VisualHudEditorPanel">
  <Grid RowDefinitions="Auto,*">
    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="4" Margin="0,0,0,4">
      <Button x:Name="AddLabelButton" Classes="compact" Content="Label"/>
      <Button x:Name="AddLineButton" Classes="compact" Content="Line"/>
      <Button x:Name="AddCircleButton" Classes="compact" Content="Circle"/>
      <Button x:Name="DeleteButton" Classes="compact" Content="Del"/>
      <Separator Width="1" Height="18" Margin="4,0"/>
      <Button x:Name="PushPreviewButton" Classes="compact" Content="Preview"/>
      <Button x:Name="SaveLayoutButton" Classes="compact" Content="Save"/>
      <Button x:Name="LoadLayoutButton" Classes="compact" Content="Load"/>
    </StackPanel>
    <Border Grid.Row="1" BorderBrush="#202020" BorderThickness="1">
      <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        <Canvas x:Name="EditorCanvas" Width="960" Height="540" Background="#101820"/>
      </ScrollViewer>
    </Border>
  </Grid>
</UserControl>
